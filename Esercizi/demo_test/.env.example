# Template per file environment variables
# Copiare questo file in .env.dev, .env.stage, .env.prod
# e compilare con i valori reali per ogni ambiente

# API Configuration
API_BASE_URL=https://api.example.com
API_KEY=your-api-key-here
API_TIMEOUT=30000

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false
ENABLE_DEBUG_LOGGING=true

# App Configuration
APP_NAME=Demo App
APP_VERSION=1.0.0

# ⚠️ IMPORTANTE: NON committare i file .env con chiavi reali!
# Aggiungere .env.* al .gitignore (tranne .env.example)
